{
  "components": {
    "schemas": {
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "RagQueryRequest": {
        "description": "Request body for a RAG retrieval query with context and message options.",
        "properties": {
          "include_context": {
            "default": true,
            "title": "Include Context",
            "type": "boolean"
          },
          "include_messages": {
            "default": true,
            "title": "Include Messages",
            "type": "boolean"
          },
          "max_context_chars": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Max Context Chars"
          },
          "query": {
            "minLength": 1,
            "title": "Query",
            "type": "string"
          },
          "top_k": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Top K"
          }
        },
        "required": [
          "query"
        ],
        "title": "RagQueryRequest",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "description": "API key header accepted by RAG middleware when API key authentication is enabled.",
        "in": "header",
        "name": "X-API-Key",
        "type": "apiKey"
      },
      "BearerAuth": {
        "description": "Bearer token accepted by RAG middleware when API key authentication is enabled.",
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "description": "Private retrieval service for platform and customer knowledge. The service returns traceable retrieval results, optional context blocks, and OpenAI-compatible grounded messages for downstream chat-completion calls.",
    "title": "Private AI Platform Kit RAG Service",
    "version": "0.20.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/healthz": {
      "get": {
        "operationId": "getRagHealth",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "title": "Response Getraghealth",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Check RAG service readiness",
        "tags": [
          "health"
        ]
      }
    },
    "/metrics": {
      "get": {
        "operationId": "getRagMetrics",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Export Prometheus metrics",
        "tags": [
          "observability"
        ]
      }
    },
    "/v1/rag/documents": {
      "get": {
        "operationId": "listRagDocuments",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "title": "Response Listragdocuments",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "security": [
          {
            "BearerAuth": []
          },
          {
            "ApiKeyAuth": []
          }
        ],
        "summary": "List indexed knowledge documents",
        "tags": [
          "retrieval"
        ]
      }
    },
    "/v1/rag/query": {
      "post": {
        "operationId": "queryRagContext",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RagQueryRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "title": "Response Queryragcontext",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "security": [
          {
            "BearerAuth": []
          },
          {
            "ApiKeyAuth": []
          }
        ],
        "summary": "Retrieve grounded context for a query",
        "tags": [
          "retrieval"
        ]
      }
    }
  },
  "tags": [
    {
      "description": "Readiness and liveness checks.",
      "name": "health"
    },
    {
      "description": "Prometheus metrics endpoints.",
      "name": "observability"
    },
    {
      "description": "Knowledge document and RAG query endpoints.",
      "name": "retrieval"
    }
  ]
}
