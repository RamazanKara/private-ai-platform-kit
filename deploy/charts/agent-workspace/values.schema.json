{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "agent-workspace values",
  "type": "object",
  "properties": {
    "namespace": {
      "type": "object",
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "create": { "type": "boolean" }
      }
    },
    "sandbox": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "runtimeClassName": { "type": "string" }
      }
    },
    "serviceAccount": { "type": "object" },
    "rbac": { "type": "object" },
    "resourceQuota": { "type": "object" },
    "limitRange": { "type": "object" },
    "workspace": {
      "type": "object",
      "properties": {
        "container": {
          "type": "object",
          "properties": {
            "image": { "type": "string", "minLength": 1 },
            "command": { "type": "array", "items": { "type": "string" } },
            "resources": { "type": "object" }
          }
        },
        "shutdownTime": { "type": "string" },
        "shutdownPolicy": { "type": "string", "enum": ["Delete", "Retain"] },
        "credentials": {
          "type": "object",
          "properties": {
            "projectedToken": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "audience": { "type": "string", "minLength": 1 },
                "expirationSeconds": { "type": "integer", "minimum": 600 },
                "mountPath": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    },
    "platform": { "type": "object" },
    "networkPolicy": { "type": "object" }
  }
}
