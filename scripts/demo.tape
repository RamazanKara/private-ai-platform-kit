# Reproducible README demo recording: vhs scripts/demo.tape
# Requires vhs, ttyd, and ffmpeg on PATH.
Output docs/assets/private-ai-platform-kit-demo.gif

Set FontSize 15
Set Width 1080
Set Height 480
Set Theme "Catppuccin Mocha"
Set Padding 12
Set TypingSpeed 40ms

Hide
Type "./scripts/demo-live.sh"
Show
Enter
Sleep 16s
