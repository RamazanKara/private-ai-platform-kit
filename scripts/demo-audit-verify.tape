# Reproducible README audit-verify recording: vhs scripts/demo-audit-verify.tape
# Requires vhs, ttyd, and ffmpeg on PATH. Regenerate with: vhs scripts/demo-audit-verify.tape
Output docs/assets/audit-verify-demo.gif

Set FontSize 15
Set Width 1100
Set Height 520
Set Theme "Catppuccin Mocha"
Set Padding 12
Set TypingSpeed 40ms

Hide
Type "./scripts/demo-audit-verify.sh"
Show
Enter
Sleep 15s
